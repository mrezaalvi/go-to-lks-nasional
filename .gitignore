# Local .terraform directory (contains providers and modules)
.terraform/

# .tfstate files (contain sensitive infrastructure data)
*.tfstate
*.tfstate.*

# Crash log files
crash.log

# Exclude all .tfvars files by default (contain secrets/passwords)
*.tfvars
*.tfvars.json

# Ignore override files (local-only configuration changes)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include override files for examples if needed
# !example_override.tf

# Ignore transient lock info files
.terraform.tfstate.lock.info
.terraform.lock.hcl

# Ignore plan output files
*.tfplan

# Ignore keypair
*.pem
